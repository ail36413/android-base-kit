<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppDemoControlsThemeOverlay" parent="ThemeOverlay.AppCompat">
        <item name="buttonStyle">@style/Widget.Androidbasekit.DemoButton</item>
        <item name="editTextStyle">@style/Widget.Androidbasekit.DemoEditText</item>
    </style>

    <style name="Widget.Androidbasekit.DemoButton" parent="Widget.AppCompat.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:backgroundTint">@color/primary</item>
    </style>

    <style name="Widget.Androidbasekit.DemoEditText" parent="Widget.AppCompat.EditText">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:backgroundTint">@color/primary</item>
    </style>

    <style name="AppDemoTitleText" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppDemoSubtitleText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="AppDemoSectionTitleText" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppDemoSectionHeaderText" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/primary_soft</item>
        <item name="android:padding">10dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppDemoItemLabelText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="AppDemoPreviewImage">
        <item name="android:layout_width">120dp</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:background">@color/card_bg</item>
        <item name="android:padding">2dp</item>
        <item name="android:scaleType">centerCrop</item>
    </style>

    <style name="AppDemoSectionHintText" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>

</resources>
